{
  "name": "@leadertechie/personal-site-kit",
  "version": "0.0.0",
  "type": "module",
  "description": "A high-performance personal website engine for Cloudflare Workers and R2",
  "repository": {
    "type": "git",
    "url": "https://github.com/leadertechie/personal-site-kit"
  },
  "author": "Techie Leader",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "public"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./prerender": {
      "types": "./dist/prerender.d.ts",
      "import": "./dist/prerender.js"
    },
    "./styles/*": "./dist/styles/*"
  },
  "scripts": {
    "build": "vite build && npm run postbuild",
    "postbuild": "cp -r src/styles dist/",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix"
  },
  "dependencies": {
    "@leadertechie/md2html": "^0.1.0-alpha.20",
    "@leadertechie/md2interact": "^0.1.0-alpha.4",
    "@leadertechie/r2tohtml": "^0.1.0-alpha.17",
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^9.18.0",
    "jsdom": "^29.0.1",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^7.3.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.0.16"
  },
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "lodash": "^4.18.1"
  }
}
